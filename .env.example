# ─── Funding Rate Bot Configuration ──────────────────────────────────────────
# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub!

# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Choose your provider: kimi, openai, anthropic, groq
# The bot will auto-configure the API endpoint and default model
LLM_PROVIDER=kimi

# Your API key for the chosen provider
LLM_API_KEY=your_api_key_here

# (Optional) Override the default model for your provider
# LLM_MODEL=kimi-k2.6          # For Kimi
# LLM_MODEL=gpt-4o-mini        # For OpenAI
# LLM_MODEL=claude-3-haiku     # For Anthropic
# LLM_MODEL=llama3-8b-8192     # For Groq

# (Optional) Override the API URL (rarely needed)
# LLM_API_URL=https://api.kimi.com/coding/v1/messages

# ─── Bot Behavior ────────────────────────────────────────────────────────────
# Alert threshold: funding rate absolute value must exceed this to trigger alert
# Default: 0.001 = 0.1%
THRESHOLD=0.001

# Assets to monitor (comma-separated)
ASSETS=BTC,ETH,SOL,AVAX,ARB,OP,LINK,UNI

# Check interval in seconds for monitoring mode
# Default: 300 = 5 minutes
CHECK_INTERVAL=300
